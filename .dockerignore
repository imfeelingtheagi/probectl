# Keep the image build context small, fast, and secret-free.
# The Dockerfile builds a single binary from the root Go module, so it only
# needs go.mod/go.sum + cmd/ + internal/ + pkg/ + migrations/ (embedded).
# Everything else is excluded.
.git/
.github/
.gitignore
.dockerignore
.editorconfig

# Workspace + integration-test module are not needed to build a binary.
go.work
go.work.sum
test/

# Other components / docs / deploy assets.
analyzer/
# web/: the UI SOURCE is needed — the image builds the SPA in a node stage and
# embeds it (UX-002, deploy/docker/Dockerfile `web` stage runs `COPY web/`).
# Exclude only the heavy/generated subdirs so `npm ci` + `npm run build` run on a
# clean, small context (the host's node_modules/dist must NOT clobber the
# in-image build), but keep the source the COPY needs.
web/node_modules/
web/dist/
web/coverage/
docs/
deploy/
proto/
buf.yaml
buf.gen.yaml

# Tests, markdown, local env, and any TLS material.
**/*_test.go
*.md
.env*
*.pem
*.key
*.crt
bin/
dist/
