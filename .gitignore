# Build output
/bin/
/dist/
*.exe
*.test
*.out
# Stray gofmt/editor backups (ARCH-007): *.go.<numeric> must never be committed.
*.go.[0-9]*
# stray root-level cmd binaries (normal builds go to /bin/)
/probectl
/probectl-control
/probectl-agent
/probectl-ebpf-agent
/probectl-endpoint

# Go
/vendor/

# Coverage
*.coverprofile
coverage.txt
coverage.out
coverage.html
coverage.xml
.coverage
.hypothesis/

# Python (analyzer/)
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# Node / frontend (web/ — framework chosen in S8a)
node_modules/
web/dist/
web/.cache/
# UX-002: the REAL UI bundle is built at image-build time and overlaid onto
# internal/webui/dist (deploy/docker/Dockerfile). Only the placeholder
# index.html is tracked; the generated assets must never be committed.
internal/webui/dist/assets/
internal/webui/dist/probectl-rum.js
internal/webui/dist/*.del.*

# Local environment & secrets — never commit secrets (CLAUDE.md §7 guardrail 6)
.env
.env.*
!.env.example
*.local

# Locally generated TLS material — never commit private keys (S3)
*.pem
*.key
*.crt
/deploy/compose/certs/
# (CODE-006: the former OIDC test-key exception is gone — the mock IdP
# generates its key at test setup; no key is ever committed.)

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
receipts/
web/coverage/
