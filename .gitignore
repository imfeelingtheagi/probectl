# Local environment & secrets — never commit secrets (CLAUDE.md §7 guardrail 6)
.env
.env.*
!.env.example
*.local

# Locally generated TLS material — never commit private keys (S3)
*.pem
*.key
*.crt
/deploy/compose/certs/
