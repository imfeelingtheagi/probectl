# probectl all-in-one (deploy/compose/probectl.yml) configuration.
# Copy to `.env` in this directory and edit. Docker Compose loads it automatically.

# --- required for production -------------------------------------------------

# Postgres superuser password for the bundled database. REQUIRED — the stack
# refuses to start while this is empty (SEC-006: no default ships).
# Generate one:  openssl rand -base64 24
POSTGRES_PASSWORD=

# At-rest encryption is ON BY DEFAULT (SEC-002). With PROBECTL_ENVELOPE_KEY
# left empty, the control plane generates a KEK on first boot and persists it
# at PROBECTL_ENVELOPE_KEY_FILE on the `controldata` volume (0600) — back that
# volume up like key material. To supply your own key (recommended for
# production; inject from your KMS/secret manager):
#   openssl rand -base64 32
PROBECTL_ENVELOPE_KEY=
PROBECTL_ENVELOPE_KEY_FILE=/var/lib/probectl/envelope.key
# Fail closed (TENANT-106): the control plane refuses to start rather than
# silently writing plaintext when no key resolves. Set false ONLY for a
# throwaway keyless quickstart.
PROBECTL_REQUIRE_AT_REST_ENCRYPTION=true

# NOTE (COMPLY-004): probectl encrypts the values IT manages. Encrypting the
# BULK telemetry volumes (Postgres, ClickHouse, object store) at rest is the
# OPERATOR's duty — dm-crypt/LUKS, ZFS, or encrypted cloud volumes. Verify
# with:  probectl-control preflight --strict   (docs/hardening.md)

# --- TLS ---------------------------------------------------------------------

# Hostnames / IPs the self-signed quickstart certificate is valid for. For a real
# deployment, set this to your public hostname(s) — or mount a CA-issued cert into
# the `certs` volume instead and remove the certgen service.
PROBECTL_TLS_HOSTS=localhost,127.0.0.1

# The stack's Postgres serves TLS (cert from the certgen one-shot) and the
# control plane connects with sslmode=require. Override PROBECTL_DATABASE_URL
# only for dev stacks without TLS — see docs/configuration.md.

# --- authentication ----------------------------------------------------------

# "session" — real OIDC SSO (the secure default; unauthenticated requests are
#             refused). Set the PROBECTL_OIDC_* values below.
# "dev"     — trusted-header all-access principal, NO authentication. EXPLICIT
#             opt-in for local evaluation only; the control plane logs a loud
#             startup warning. Never in production.
PROBECTL_AUTH_MODE=session

# OIDC SSO (required when PROBECTL_AUTH_MODE=session).
PROBECTL_OIDC_ISSUER=
PROBECTL_OIDC_CLIENT_ID=
PROBECTL_OIDC_CLIENT_SECRET=
PROBECTL_OIDC_REDIRECT_URL=https://localhost:8443/auth/callback

# --- misc --------------------------------------------------------------------

# RFC 9116 disclosure contact served at /.well-known/security.txt.
PROBECTL_SECURITY_CONTACT=mailto:security@your-org.example

# The compose default is PINNED to a release (SUPPLY-001). Digest-pin for
# maximum immutability, e.g.:
# PROBECTL_IMAGE=ghcr.io/imfeelingtheagi/probectl-control:v0.1.0
