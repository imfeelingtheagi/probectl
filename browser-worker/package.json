{
  "name": "netctl-browser-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "netctl S36 Playwright browser-worker: runs one transaction script in headless Chromium and emits a JSON result.",
  "bin": {
    "netctl-browser-worker": "worker.mjs"
  },
